            <label for="mensagem" class="block text-sm font-medium mb-1">Mensagem / Descreva sua Propriedade</label>
            <textarea id="mensagem" rows="4" required class="w-full p-3 rounded-lg border border-texto-secundario/30 bg-background-light dark:bg-background-dark text-texto-principal dark:text-texto-principalDark focus:ring-2 focus:ring-primary focus:outline-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-primary hover:bg-primary-darker text-white font-bold p-4 rounded-lg transition-colors">
            Enviar Mensagem
          </button>
        </form>
        <div id="mensagemSucesso" class="hidden mt-6 p-4 rounded-lg bg-emerald-100 dark:bg-emerald-950 text-emerald-800 dark:text-emerald-200 text-center font-medium border border-emerald-200 dark:border-emerald-800">
          ✓ Obrigado! Seus dados foram enviados com sucesso. Entraremos em contato!
        </div>
      </div>
    </div>
  </section>

  <footer class="bg-emerald-900 dark:bg-neutral-950 text-emerald-100 dark:text-neutral-400 py-12 transition-colors border-t border-neutral-800">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center space-y-4">
      <p class="text-xl font-bold text-white">AgroForte</p>
      <p class="text-sm text-emerald-200/70 max-w-md mx-auto">Desenvolvendo soluções agro-ecológicas sustentáveis de alta performance para o produtor rural moderno.</p>
      <div class="pt-6 border-t border-emerald-800 dark:border-neutral-800 text-xs text-emerald-300/50">
        &copy; 2026 AgroForte Tecnologia Sustentável. Todos os direitos reservados.
      </div>
    </div>
  </footer>

  <script>
    // 1. Alternador de Tema Dinâmico (Modo Escuro / Claro)
    const btnTema = document.getElementById('btnTema');
    const btnTemaMobile = document.getElementById('btnTemaMobile');
    
    function toggleTheme() {
      if (document.documentElement.classList.contains('dark')) {
        document.documentElement.classList.remove('dark');
        btnTema.textContent = 'Modo Escuro';
        btnTemaMobile.textContent = 'Tema';
      } else {
        document.documentElement.classList.add('dark');
        btnTema.textContent = 'Modo Claro';
        btnTemaMobile.textContent = 'Claro';
      }
    }
    btnTema.addEventListener('click', toggleTheme);
    btnTemaMobile.addEventListener('click', toggleTheme);

    // 2. Controle do Menu Mobile (Abrir e Fechar)
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuLinks = mobileMenu.querySelectorAll('a');

    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    mobileMenuLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });

    // 3. Simulador Web Interativo
    const hectaresInput = document.getElementById('hectaresInput');
    const resAgua = document.getElementById('resAgua');
    const resCarbono = document.getElementById('resCarbono');
    const resProd = document.getElementById('resProd');

    hectaresInput.addEventListener('input', (e) => {
      const hectares = parseFloat(e.target.value);

      if (isNaN(hectares) || hectares <= 0) {
        resAgua.textContent = '0 L';
        resCarbono.textContent = '0 kg';
        resProd.textContent = '+0%';
        return;
      }

      const aguaPoupada = hectares * 12000;  
      const co2Evitado = hectares * 450;     
      const eficiencia = Math.min(35, (hectares * 0.08) + 15).toFixed(1); 

      resAgua.textContent = `${aguaPoupada.toLocaleString('pt-BR')} L`;
      resCarbono.textContent = `${co2Evitado.toLocaleString('pt-BR')} kg`;
      resProd.textContent = `+${eficiencia}%`;
    });

    // 4. Envio do Formulário de Contato com Feedback Visual
    const formContato = document.getElementById('formContato');
    const mensagemSucesso = document.getElementById('mensagemSucesso');

    formContato.addEventListener('submit', (e) => {
      e.preventDefault(); 
      
      mensagemSucesso.classList.remove('hidden');
      formContato.reset();

      setTimeout(() => {
        mensagemSucesso.classList.add('hidden');
      }, 5000);
    });
  </script>
</body>
</html>
